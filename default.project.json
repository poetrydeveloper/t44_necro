{
	"name": "NecromancerRoguelite",
	"globIgnorePaths": ["**/package.json", "**/tsconfig.json"],
	"tree": {
		"$className": "DataModel",

		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"rbxts_include": {
				"$path": "include",
				"node_modules": {
					"$className": "Folder",
					"@flamework": {
						"$path": "node_modules/@flamework"
					},
					"@rbxts": {
						"$path": "node_modules/@rbxts"
					}
				}
			},
			"TS": { 
				"$path": "out/shared" 
			}
		},

		"ServerScriptService": {
			"$className": "ServerScriptService",
			"TS": { 
				"$path": "out/server" 
			}
		},

		"ServerStorage": {
			"$className": "ServerStorage",
			"Models": {
				"$path": "assets/models"
			}
		},

		"StarterPlayer": {
			"$className": "StarterPlayer",
			"StarterPlayerScripts": {
				"$className": "StarterPlayerScripts",
				"TS": { 
					"$path": "out/client" 
				}
			}
		},

		"Workspace": {
			"$className": "Workspace",
			"World": {
				"$className": "Folder",
				"Locations": {
					"$className": "Folder",
					"WellSpawn": {
						"$className": "Part",
						"$properties": {
							"Anchored": true,
							"CanCollide": false,
							"Transparency": 0.5
						}
					}
				},
				"Enemies": { "$className": "Folder" },
				"Corpses": { "$className": "Folder" },
				"Projectiles": { "$className": "Folder" }
			}
		}
	}
}
