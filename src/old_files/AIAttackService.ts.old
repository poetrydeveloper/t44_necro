// src/server/services/AIAttackService.ts
import { Service, OnTick, Dependency } from "@flamework/core";
import { Components } from "@flamework/components";
import { Players } from "@rbxts/services";
import { SummonComponent } from "server/components/SummonComponent";
import { EnemyComponent } from "server/components/EnemyComponent";
import { LifeComponent } from "server/components/LifeComponent";
import { CombatNetworking } from "shared/networking/CombatNetworking";

@Service({})
export class AIAttackService implements OnTick {
	private components = Dependency<Components>();
	private events = CombatNetworking.createServer({});

	// 🛠 Увеличили радиус для теста (было 6)
	private readonly ATTACK_RANGE = 15; 
	private readonly ATTACK_COOLDOWN = 1.2;
	private readonly DAMAGE = 8;

	private lastAttackTime = new Map<string, number>();
	private debugCounter = 0; // Для редких логов

	// 🛠 Добавили onStart для проверки загрузки сервиса
	onStart() {
		print("[AIAttackService] ⚔️ Сервис атаки ИИ запущен!");
	}

	onTick(dt: number) {
		const summons = this.components.getAllComponents<SummonComponent>(SummonComponent);
		const enemies = this.components.getAllComponents<EnemyComponent>(EnemyComponent);

		// 🔍 Редкий лог: сколько юнитов и врагов видит сервис
		this.debugCounter++;
		if (this.debugCounter % 60 === 0 && (summons.size() > 0 || enemies.size() > 0)) {
			print(`[AIAttack] 🔍 Вижу: ${summons.size()} скелетов, ${enemies.size()} врагов`);
		}

		for (const summon of summons) {
			const model = summon.instance;
			if (!model.Parent) continue;
			if (summon.ownerId === 0) continue;

			const summonRoot = model.FindFirstChild("HumanoidRootPart") as BasePart;
			if (!summonRoot) {
				print(`[AIAttack] ❌ ${model.Name}: нет HumanoidRootPart`);
				continue;
			}

			const now = os.clock();
			const lastAttack = this.lastAttackTime.get(model.Name) || 0;
			
			if (now - lastAttack < this.ATTACK_COOLDOWN) continue;

			// Ищем ближайшего живого врага
			let nearestEnemy: EnemyComponent | undefined;
			let nearestDist = this.ATTACK_RANGE;

			for (const enemy of enemies) {
				const life = this.components.getComponent<LifeComponent>(enemy.instance);
				if (!life || !life.isAlive()) continue;

				const enemyRoot = enemy.instance.FindFirstChild("HumanoidRootPart") as BasePart;
				if (!enemyRoot) continue;

				const dist = summonRoot.Position.sub(enemyRoot.Position).Magnitude;
				if (dist < nearestDist) {
					nearestDist = dist;
					nearestEnemy = enemy;
				}
			}

			// 🔍 Лог: если враг найден в радиусе
			if (nearestEnemy) {
				const life = this.components.getComponent<LifeComponent>(nearestEnemy.instance);
				if (life && life.isAlive()) {
					life.takeDamage(this.DAMAGE);

					const owner = Players.GetPlayerByUserId(summon.ownerId);
					const targetRoot = nearestEnemy.instance.FindFirstChild("HumanoidRootPart") as BasePart;
					
					if (targetRoot && owner) {
						this.events.showDamagePopup(
							owner,
							nearestEnemy.instance.Name,
							this.DAMAGE,
							targetRoot.Position.add(new Vector3(0, 3, 0))
						);
					}

					this.lastAttackTime.set(model.Name, now);
					print(`[AIAttack] ⚔️ ${model.Name} атаковал ${nearestEnemy.instance.Name} (дист: ${math.floor(nearestDist)})`);
				}
			} else {
				// 🔍 Лог: если врагов нет в радиусе (раз в 2 секунды, чтобы не спамить)
				if (this.debugCounter % 120 === 0) {
					print(`[AIAttack] 📍 ${model.Name}: врагов в радиусе ${this.ATTACK_RANGE} не найдено (ближайший: ${math.floor(nearestDist > 100 ? 999 : nearestDist)} студов)`);
				}
			}
		}
	}
}